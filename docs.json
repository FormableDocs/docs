      "label": "Dashboard",
      "href": "https://app.formabledocs.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/formabledocs",
      "linkedin": "https://linkedin.com/company/formabledocs"
    }
  }
