{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Formable API",
  "colors": {
    "primary": "#4F46E5",
    "light": "#818CF8",
    "dark": "#4338CA"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "developer-account",
              "quickstart",
              "authentication",
              "concepts"
            ]
          },
          {
            "group": "Walkthroughs",
            "pages": [
              "walkthroughs/embedded-templates",
              "walkthroughs/embedded-signing",
              "walkthroughs/redlining"
            ]
          },
          {
            "group": "Migrations",
            "pages": [
              {
                "group": "Dropbox Sign",
                "pages": [
                  "migrations/dropbox-sign/embedded-templates",
                  "migrations/dropbox-sign/embedded-signing"
                ]
              },
              {
                "group": "DocuSign",
                "pages": [
                  "migrations/docusign/embedded-templates",
                  "migrations/docusign/embedded-signing"
                ]
              }
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview",
              "webhooks/verifying-webhooks",
              "webhooks/events"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Templates",
            "pages": [
              "api-reference/endpoint/create-template",
              "api-reference/endpoint/create-template-edit-url"
            ]
          },
          {
            "group": "Signature Requests",
            "pages": [
              "api-reference/endpoint/create-signature-request",
              "api-reference/endpoint/list-signature-requests",
              "api-reference/endpoint/get-signature-request",
              "api-reference/endpoint/create-signing-url",
              "api-reference/endpoint/get-signed-envelope",
              "api-reference/endpoint/get-signature-request-events"
            ]
          },
          {
            "group": "Redlining",
            "pages": [
              "api-reference/endpoint/create-redline-request",
              "api-reference/endpoint/list-redline-requests",
              "api-reference/endpoint/get-redline-request",
              "api-reference/endpoint/put-redline-members",
              "api-reference/endpoint/create-redline-url",
              "api-reference/endpoint/get-redline-request-events"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "api-reference/endpoint/get-billing"
            ]
          },
          {
            "group": "Health",
            "pages": [
              "api-reference/endpoint/health-check"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/guides/e-signatures",
      "destination": "/walkthroughs/embedded-signing"
    },
    {
      "source": "/guides/embedded-signing",
      "destination": "/walkthroughs/embedded-signing"
    },
    {
      "source": "/guides/templates",
      "destination": "/walkthroughs/embedded-templates"
    },
    {
      "source": "/walkthroughs/templates",
      "destination": "/walkthroughs/embedded-templates"
    },
    {
      "source": "/guides/redlining",
      "destination": "/walkthroughs/redlining"
    },
    {
      "source": "/migrations/dropbox-sign",
      "destination": "/migrations/dropbox-sign/embedded-signing"
    },
    {
      "source": "/migrations/docusign",
      "destination": "/migrations/docusign/embedded-signing"
    }
  ],
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
